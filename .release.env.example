# Copy to .release.env for maintainer-only Azad release settings.
#
# This file is read by `just dist`. It should not contain Apple passwords,
# exported certificates, or keychain material. Store notarization credentials in
# the macOS Keychain with:
#   xcrun notarytool store-credentials "azad-notarization" \
#     --apple-id "you@example.com" \
#     --team-id "35A87BDK48"
#
# Public distribution builds must be signed with Developer ID and notarized.
# Prefer the 40-character Developer ID Application certificate hash from:
#   security find-identity -v -p codesigning "$HOME/Library/Keychains/login.keychain-db"
#
# AZAD_SIGNING_IDENTITY="0123456789ABCDEF0123456789ABCDEF01234567"
# AZAD_NOTARIZATION_PROFILE="azad-notarization"
#
# Explicit environment variables override this file.
