# Copy to .codesign.env for machine-local Azad signing settings.
#
# `just install` works without this file. Set AZAD_CODESIGN_IDENTITY only on
# development machines where you want macOS TCC permissions to survive rebuilds.
#
# Prefer the 40-character certificate hash from:
#   security find-identity -v -p codesigning "$HOME/Library/Keychains/login.keychain-db"
#
# AZAD_CODESIGN_IDENTITY="0123456789ABCDEF0123456789ABCDEF01234567"
#
# Explicit environment variables override this file.
